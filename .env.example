# Environment variables for AB Interior Works (Create React App)
# Copy this file to .env.local and fill in the values.

# Required: Web3Forms Access Key (used to send Contact/Quote form emails)
# Get your key from https://web3forms.com/ after creating an access key.
REACT_APP_WEB3FORMS_KEY=your_web3forms_access_key_here

# Optional: Webhook to trigger SMS/CRM automations (Zapier/Twilio Function/Make)
# If set, form submissions will also POST a JSON payload to this URL.
REACT_APP_QUOTE_WEBHOOK=https://ntfy.sh/ab-interior-quotes-9f2c7a12
